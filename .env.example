# Whisper
WHISPER_MODEL_SIZE=small
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# Groq API (direct)
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_API_KEY=
LLM_MODEL=llama-3.1-8b-instant
LLM_TIMEOUT_SECONDS=60
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=5000
LLM_MAX_RETRIES=3
LLM_RETRY_BACKOFF_SECONDS=0.7
LLM_HEALTH_TTL_SECONDS=30

# App
APP_PORT=8000
